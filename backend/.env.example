PORT=3001

# Banco de Dados (MySQL)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=valorant_tourney

# Autenticação
JWT_SECRET=seu_jwt_secret_super_seguro

# Integração com HenrikDev API (Valorant)
