# ──────────────────────────────────────────────
#  VTourney Backend — .env.example
#  Copie este arquivo para .env e preencha os valores reais
# ──────────────────────────────────────────────

PORT=3001

# Banco de dados (MySQL / Aiven)
DB_HOST=seu-host.aivencloud.com
DB_USER=avnadmin
DB_PASSWORD=SUA_SENHA_AQUI
DB_NAME=valorant_tourney
DB_PORT=28411

# JWT — gere um secret forte: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TROQUE_POR_UM_SEGREDO_FORTE_DE_64_CHARS

# URLs (atualizar para produção)
ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# HenrikDev Valorant API
VALORANT_API_KEY=HDEV-xxxx-xxxx-xxxx-xxxx
VALORANT_API_BASE_URL=https://api.henrikdev.xyz/valorant

# Cloudinary — upload de avatares
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=seu_api_secret

# Discord OAuth
DISCORD_CLIENT_ID=seu_client_id
DISCORD_CLIENT_SECRET=seu_client_secret
DISCORD_REDIRECT_URI=http://localhost:3001/api/discord/callback
