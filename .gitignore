# ──────────────────────────────────────────────
#  VTourney — Root .gitignore
# ──────────────────────────────────────────────

# ── Segredos ──
**/.env
**/.env.local
**/.env.*.local

# ── Node / Backend ──
backend/node_modules/
backend/logs/
backend/*.log
backend/coverage/

# ── Next.js / Frontend ──
frontend/.next/
frontend/out/
frontend/node_modules/
frontend/.env.local
frontend/coverage/

# ── Sistema ──
.DS_Store
Thumbs.db
*.log
*.tmp

# ── Arquivos de debug / gerados automaticamente ──
analyze.js
struct.json
tree.txt
backend/migracao_bye.js

# ── Editores ──
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
